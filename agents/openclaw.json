{
  "name": "face-library",
  "version": "1.0.0",
  "description": "Secure AI Likeness Licensing Infrastructure -- Multi-agent platform protecting human identity rights in generative AI",

  "env": {
    "FLOCK_API_KEY": "${FLOCK_API_KEY}",
    "ZAI_API_KEY": "${ZAI_API_KEY}",
    "ANYWAY_API_KEY": "${ANYWAY_API_KEY}"
  },

  "models": {
    "mode": "merge",
    "providers": {
      "flock": {
        "baseUrl": "https://api.flock.io/v1",
        "apiKey": "${FLOCK_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-30b-a3b-instruct-2507",
            "name": "Qwen3 30B (Fast)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3-235b-a22b-instruct-2507",
            "name": "Qwen3 235B (Creative/Negotiation)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3-235b-a22b-thinking-2507",
            "name": "Qwen3 235B Thinking (Reasoning/Fallback)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-v3.2",
            "name": "DeepSeek V3.2 (Analysis/Compliance)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 64000,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (Long Context)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "zai": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "${ZAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-4-plus",
            "name": "GLM-4 Plus (Contract Generation + Compliance Summary)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "compliance",
        "name": "Compliance & Risk Agent",
        "description": "Assesses content risk, brand risk, legal risk, ethical risk, and geographic risk. Uses FLock DeepSeek for analysis and Z.AI GLM for executive summaries.",
        "workspace": "~/.openclaw/face-library/compliance",
        "model": {
          "primary": "flock/deepseek-v3.2",
          "secondary": "zai/glm-4-plus"
        },
        "sdg": ["SDG 10", "SDG 16"]
      },
      {
        "id": "negotiator",
        "name": "Negotiator Agent",
        "description": "Proposes dynamic pricing and licensing terms that protect talent interests while remaining commercially viable. Ensures SDG 8 fair compensation.",
        "workspace": "~/.openclaw/face-library/negotiator",
        "model": {
          "primary": "flock/qwen3-235b-a22b-instruct-2507"
        },
        "sdg": ["SDG 8", "SDG 10"]
      },
      {
        "id": "contract",
        "name": "IP Contract Generation Agent",
        "description": "Generates full UK-law-compliant IP licensing agreements with 12 sections covering GDPR, Copyright Act 1988, and dispute resolution.",
        "workspace": "~/.openclaw/face-library/contract",
        "model": {
          "primary": "zai/glm-4-plus",
          "fallback": "flock/qwen3-235b-a22b-thinking-2507"
        },
        "sdg": ["SDG 16"]
      },
      {
        "id": "search",
        "name": "Talent Search Agent",
        "description": "AI-driven talent discovery for brands. Ranks talent by relevance, flags conflicts, and promotes fair representation.",
        "workspace": "~/.openclaw/face-library/search",
        "model": {
          "primary": "flock/deepseek-v3.2"
        },
        "sdg": ["SDG 8", "SDG 10"]
      },
      {
        "id": "audit",
        "name": "Audit & Traceability Agent",
        "description": "Logs every agent action with timestamps, model info, and token usage. Provides full audit trails, per-agent statistics, and decision history.",
        "workspace": "~/.openclaw/face-library/audit",
        "model": {
          "primary": "local"
        },
        "sdg": ["SDG 16"]
      }
    ],
    "defaults": {
      "workspace": "~/.openclaw/face-library/default"
    }
  },

  "plugins": {
    "enabled": true,
    "allow": ["anyway-openclaw"],
    "entries": {
      "anyway-openclaw": {
        "enabled": true,
        "config": {
          "endpoint": "https://trace-dev-collector.anyway.sh",
          "serviceName": "face-library",
          "captureContent": true,
          "sampleRate": 1.0,
          "flushIntervalMs": 5000,
          "spanTypes": ["session", "agent", "llm", "tool"]
        }
      }
    }
  }
}
