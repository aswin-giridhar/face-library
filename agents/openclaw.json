{
  "name": "face-library",
  "version": "2.0.0",
  "description": "Secure AI Likeness Licensing Infrastructure — 9 autonomous agents protecting human identity rights in generative AI. Built on OpenClaw for the UK AI Agent Hackathon EP4.",
  "framework": "openclaw",

  "env": {
    "FLOCK_API_KEY": "${FLOCK_API_KEY}",
    "ZAI_API_KEY": "${ZAI_API_KEY}",
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "ANYWAY_API_KEY": "${ANYWAY_API_KEY}",
    "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}",
    "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}"
  },

  "models": {
    "mode": "merge",
    "providers": {
      "flock": {
        "baseUrl": "https://api.flock.io/v1",
        "apiKey": "${FLOCK_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-30b-a3b-instruct-2507",
            "name": "Qwen3 30B (Fast)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3-235b-a22b-instruct-2507",
            "name": "Qwen3 235B (Creative/Negotiation)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3-235b-a22b-thinking-2507",
            "name": "Qwen3 235B Thinking (Reasoning/Fallback)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-v3.2",
            "name": "DeepSeek V3.2 (Analysis/Compliance)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 64000,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (Long Context)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "zai": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "${ZAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-4-plus",
            "name": "GLM-4 Plus (Contract Generation + Compliance Summary)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "z-ai/glm-4.5",
            "name": "GLM-4.5 via OpenRouter (Z.AI fallback)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "compliance",
        "name": "Compliance & Risk Agent",
        "description": "Assesses content risk, brand risk, legal risk, ethical risk, and geographic risk for every license request. Uses dual-model approach: FLock DeepSeek for structured analysis, Z.AI GLM for executive summaries.",
        "workspace": "~/.openclaw/face-library/compliance",
        "model": {
          "primary": "flock/deepseek-v3.2",
          "secondary": "zai/glm-4-plus"
        },
        "sdg": ["SDG 10", "SDG 16"],
        "tools": ["risk_assessment", "gdpr_check", "content_classification"]
      },
      {
        "id": "negotiator",
        "name": "Pricing Negotiator Agent",
        "description": "Proposes dynamic pricing and licensing terms that protect talent interests while remaining commercially viable. Ensures SDG 8 fair compensation with market-rate analysis.",
        "workspace": "~/.openclaw/face-library/negotiator",
        "model": {
          "primary": "flock/qwen3-235b-a22b-instruct-2507"
        },
        "sdg": ["SDG 8", "SDG 10"],
        "tools": ["price_calculator", "market_analysis", "sdg_alignment"]
      },
      {
        "id": "contract",
        "name": "IP Contract Generation Agent",
        "description": "Generates full UK-law-compliant IP licensing agreements with 12 sections covering GDPR, Copyright Act 1988, Consumer Rights Act 2015, and dispute resolution.",
        "workspace": "~/.openclaw/face-library/contract",
        "model": {
          "primary": "zai/glm-4-plus",
          "fallback": "flock/qwen3-235b-a22b-thinking-2507"
        },
        "sdg": ["SDG 16"],
        "tools": ["contract_generation", "legal_validation"]
      },
      {
        "id": "gen_orchestrator",
        "name": "Avatar Generation Agent",
        "description": "Creates detailed image/avatar generation prompts for licensed content based on talent profile and campaign requirements.",
        "workspace": "~/.openclaw/face-library/gen_orchestrator",
        "model": {
          "primary": "flock/deepseek-v3.2"
        },
        "sdg": ["SDG 10"],
        "tools": ["prompt_generation", "style_matching"]
      },
      {
        "id": "fingerprint",
        "name": "Likeness Fingerprint Agent",
        "description": "Scans for unauthorized use of talent likeness across platforms. Generates fingerprint IDs and monitors for violations.",
        "workspace": "~/.openclaw/face-library/fingerprint",
        "model": {
          "primary": "flock/deepseek-v3.2"
        },
        "sdg": ["SDG 16"],
        "tools": ["fingerprint_scan", "violation_detection", "platform_monitoring"]
      },
      {
        "id": "web3_contract",
        "name": "Web3 Rights Agent",
        "description": "Generates ERC-721 smart contract metadata for on-chain IP rights tracking on Polygon. Integrates with Animoca Brands ecosystem.",
        "workspace": "~/.openclaw/face-library/web3",
        "model": {
          "primary": "local"
        },
        "sdg": ["SDG 16"],
        "tools": ["erc721_metadata", "polygon_deploy", "token_management"]
      },
      {
        "id": "search",
        "name": "Talent Discovery Agent",
        "description": "AI-driven talent discovery for brands. Ranks talent by relevance to campaign requirements, flags conflicts, and promotes fair representation.",
        "workspace": "~/.openclaw/face-library/search",
        "model": {
          "primary": "flock/deepseek-v3.2"
        },
        "sdg": ["SDG 8", "SDG 10"],
        "tools": ["talent_search", "relevance_scoring", "conflict_detection"]
      },
      {
        "id": "audit",
        "name": "Audit & Traceability Agent",
        "description": "Logs every agent action with timestamps, model info, and token usage. Provides full audit trails, per-agent statistics, and decision history for compliance.",
        "workspace": "~/.openclaw/face-library/audit",
        "model": {
          "primary": "local"
        },
        "sdg": ["SDG 16"],
        "tools": ["audit_log", "statistics", "decision_history"]
      },
      {
        "id": "orchestrator",
        "name": "Pipeline Orchestrator",
        "description": "Coordinates all 8 agents in the 7-step licensing pipeline. Manages agent routing, error handling, metadata tracking, and session-level tracing.",
        "workspace": "~/.openclaw/face-library/orchestrator",
        "model": {
          "primary": "local"
        },
        "sdg": ["SDG 8", "SDG 10", "SDG 16"],
        "tools": ["pipeline_coordination", "agent_routing", "session_management"]
      }
    ],
    "defaults": {
      "workspace": "~/.openclaw/face-library/default"
    }
  },

  "pipeline": {
    "name": "license_processing",
    "description": "7-step autonomous licensing pipeline with human-in-the-loop approval",
    "steps": [
      {"agent": "compliance", "action": "risk_assessment", "blocking": true},
      {"agent": "negotiator", "action": "price_negotiation", "blocking": false},
      {"agent": "contract", "action": "contract_generation", "blocking": false},
      {"agent": "gen_orchestrator", "action": "avatar_prompt", "blocking": false},
      {"agent": "fingerprint", "action": "likeness_scan", "blocking": false},
      {"agent": "web3_contract", "action": "onchain_rights", "blocking": false},
      {"agent": "audit", "action": "pipeline_summary", "blocking": false}
    ],
    "human_approval": {
      "required": true,
      "approver": "talent",
      "after_step": "audit"
    }
  },

  "channels": {
    "web": {
      "type": "nextjs",
      "url": "https://face-library.vercel.app",
      "description": "17-page Next.js web application with role-based dashboards"
    },
    "api": {
      "type": "rest",
      "url": "https://face-library.onrender.com",
      "description": "38 REST API endpoints with Swagger docs"
    },
    "telegram": {
      "type": "telegram",
      "bot": "@FaceLibraryBot",
      "description": "Telegram bot for talent search, license status, and notifications"
    }
  },

  "plugins": {
    "enabled": true,
    "allow": ["anyway-openclaw"],
    "entries": {
      "anyway-openclaw": {
        "enabled": true,
        "config": {
          "endpoint": "https://trace-dev-collector.anyway.sh",
          "serviceName": "face-library",
          "captureContent": true,
          "sampleRate": 1.0,
          "flushIntervalMs": 5000,
          "spanTypes": ["session", "agent", "llm", "tool"]
        }
      }
    }
  },

  "commercialization": {
    "stripe": {
      "enabled": true,
      "mode": "test",
      "products": {
        "license_payment": "License fee payment for likeness usage",
        "platform_fee": "Face Library platform service fee (10%)"
      },
      "pricing_api": "/api/pricing/estimate",
      "checkout_api": "/api/payments/checkout"
    }
  }
}
